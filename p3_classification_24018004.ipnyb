   "source": [
    "### 3.2 Clustering\n",
    "\n",
    "I'll apply K-Means and Agglomerative Clustering to see if natural groups exist in the data."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "00126b5b-cfd3-45fe-99b6-c4b00a61d779",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1400x500 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Best k by silhouette: 3\n"
     ]
    }
   ],
   "source": [
    "inertias = []\n",
    "silhouettes = []\n",
    "K_range = range(2, 11)\n",
    "\n",
    "for k in K_range:\n",
    "    km = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
    "    labels = km.fit_predict(X_train_scaled)\n",
    "    inertias.append(km.inertia_)\n",
    "    silhouettes.append(silhouette_score(X_train_scaled, labels))\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "axes[0].plot(K_range, inertias, 'bo-')\n",
    "axes[0].set_xlabel('k')\n",
    "axes[0].set_ylabel('Inertia')\n",
    "axes[0].set_title('K-Means — Elbow Curve')\n",
    "\n",
    "axes[1].plot(K_range, silhouettes, 'ro-')\n",
    "axes[1].set_xlabel('k')\n",
    "axes[1].set_ylabel('Silhouette Score')\n",
    "axes[1].set_title('K-Means — Silhouette Score')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('kmeans_tuning.png', dpi=100, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "best_k = K_range[np.argmax(silhouettes)]\n",
    "print(f\"Best k by silhouette: {best_k}\")"
   ]
  },
